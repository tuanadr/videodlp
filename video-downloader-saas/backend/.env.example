# Cấu hình môi trường cho backend

# Cấu hình chung
NODE_ENV=production
PORT=5000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=1h
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRE=7d

# Database Configuration
# Sử dụng SQLite (đặt USE_SQLITE=true) hoặc PostgreSQL (đặt USE_SQLITE=false)
USE_SQLITE=false

# Cấu hình SQLite (chỉ cần nếu USE_SQLITE=true)
SQLITE_PATH=./database/videodlp.db
SQLITE_PRAGMA_JOURNAL_MODE=WAL
SQLITE_PRAGMA_SYNCHRONOUS=NORMAL

# Cấu hình PostgreSQL (chỉ cần nếu USE_SQLITE=false)
DB_HOST=videodlp-db
DB_PORT=5432
DB_NAME=videodlp
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false
SYNC_DATABASE=false

# Cấu hình Redis (tùy chọn)
REDIS_HOST=videodlp-redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Frontend URL
FRONTEND_URL=https://yourdomain.com

# Stripe Configuration (nếu sử dụng)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Đường dẫn thư mục
DOWNLOADS_DIR=./downloads
LOGS_DIR=./logs

# Tối ưu hóa
UV_THREADPOOL_SIZE=4